# Maintainer: kreijstal <kreijstal@hotmail.com>

pkgname=xcb-util-wm
pkgver=0.4.2
pkgrel=1
pkgdesc="Client and window-manager helpers for X C Binding"
arch=('x86_64')
url="https://xcb.freedesktop.org/"
license=('spdx:MIT')
depends=('libxcb')
makedepends=('gcc'
             'pkgconf')
source=("https://xorg.freedesktop.org/releases/individual/xcb/${pkgname}-${pkgver}.tar.xz")
sha256sums=('62c34e21d06264687faea7edbf63632c9f04d55e72114aa4a57bb95e4f888a0b')

build() {
  cd "${pkgname}-${pkgver}"

  ./configure \
    --prefix=/usr \
    --build=${CHOST} \
    --host=${CHOST} \
    --disable-static

  make
}

check() {
  cd "${pkgname}-${pkgver}"
  make check
}

package() {
  cd "${pkgname}-${pkgver}"
  make DESTDIR="${pkgdir}" install
  install -Dm644 COPYING "${pkgdir}/usr/share/licenses/${pkgname}/COPYING"
}
