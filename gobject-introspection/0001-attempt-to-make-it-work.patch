+                def preprocess(self, source, output_file, macros, include_dirs, extra_postargs):
+                    cmd = self.preprocessor + [source, '-o', output_file]
+                    for name, value in macros:
+                        if value is None:
+                            cmd.append(f'-D{name}')
+                        else:
+                            cmd.append(f'-D{name}={value}')
+                    for d in include_dirs:
+                        cmd.append(f'-I{d}')
+                    cmd.extend(extra_postargs)
+                    subprocess.run(cmd, check=True) # Use check=True to raise an error on non-zero exit
