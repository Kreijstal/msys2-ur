diff --git a/configure.ac b/configure.ac
index c3677b0..c35798a 100644
--- a/configure.ac
+++ b/configure.ac
@@ -288,6 +288,25 @@ if test "x$platform_win32" = "xyes"; then
   AM_CHECK_PYTHON_LIBS(, AC_MSG_ERROR([Python libs not found. Windows requires Python modules to be explicitly linked to libpython.]))
 fi
 
+
+# Explicitly check for Python library
+AC_MSG_CHECKING([for Python library])
+PYTHON_LIBS=`$PYTHON-config --ldflags`
+AC_SUBST(PYTHON_LIBS)
+AC_MSG_RESULT([$PYTHON_LIBS])
+
+# For MSYS/Cygwin, we need to ensure -lpython is included
+case "$host" in
+*-*-cygwin* | *-*-msys*)
+        PYTHON_VERSION=`$PYTHON -c "import sys; print('%d.%d' % sys.version_info[:2])"`
+        PYTHON_LIBS="$PYTHON_LIBS -lpython$PYTHON_VERSION"
+        ;;
+esac
+
+# Update LDFLAGS to include Python library path
+PYTHON_LIBDIR=`$PYTHON -c "import distutils.sysconfig; print(distutils.sysconfig.get_config_var('LIBDIR'))"`
+LDFLAGS="$LDFLAGS -L$PYTHON_LIBDIR"
+
 dnl Not enabled by default until 3.6 cycle when we can propose mako as
 dnl an external dependency
 AC_ARG_ENABLE(doctool,[  --disable-doctool           disable g-ir-doc-tool ],,enable_doctool=auto)
