From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: MSYS2 packaging <packaging@msys2.org>
Date: Wed, 20 May 2026 12:00:00 +0000
Subject: [PATCH] meson: remove flex's C __STDC_VERSION__ define for Cygwin C++

The C++ GLSL scanner is generated by flex, which emits:

  #define __STDC_VERSION__ 199901

before including system headers.  On Cygwin this makes sys/cdefs.h map
__restrict to the C keyword restrict, which is not valid C++ in the
system header prototypes.  Strip that generated define for the scanner.
---
 src/compiler/glsl/meson.build | 8 +++++++-
 1 file changed, 7 insertions(+), 1 deletion(-)

diff --git a/src/compiler/glsl/meson.build b/src/compiler/glsl/meson.build
index 1111111..2222222 100644
--- a/src/compiler/glsl/meson.build
+++ b/src/compiler/glsl/meson.build
@@ -37,7 +37,13 @@ glsl_lexer_cpp = custom_target(
   'glsl_lexer_cpp',
   input : 'glsl_lexer.ll',
   output : 'glsl_lexer.cpp',
-  command : [prog_flex_cpp, '-o', '@OUTPUT@', '@INPUT@'],
+  command : [
+    prog_python, '-c',
+    'import pathlib, subprocess, sys; subprocess.check_call([sys.argv[1], "-o", sys.argv[2], sys.argv[3]]); p = pathlib.Path(sys.argv[2]); p.write_text(p.read_text().replace("#define __STDC_VERSION__ 199901" + chr(10), "", 1))',
+    prog_flex_cpp,
+    '@OUTPUT@',
+    '@INPUT@',
+  ],
 )
 
 ir_expression_operation_constant_h = custom_target(
