# Maintainer: kreijstal <kreijstal@hotmail.com>

pkgname=lzo
pkgver=2.10
pkgrel=5
pkgdesc="Portable lossless data compression library"
arch=('x86_64')
url="https://www.oberhumer.com/opensource/lzo"
license=('GPL')
source=(https://www.oberhumer.com/opensource/lzo/download/lzo-${pkgver}.tar.gz)
sha256sums=('SKIP')  # Replace SKIP with the actual checksum

depends=()
makedepends=('gcc')

build() {
  cd lzo-${pkgver}

  ./configure --prefix=/usr --enable-shared
  make

  # build minilzo
  gcc $CPPFLAGS $CFLAGS -fpic -Iinclude/lzo -o minilzo/minilzo.o -c minilzo/minilzo.c
  gcc $LDFLAGS -shared -o libminilzo.so.0 -Wl,-soname,libminilzo.so.0 minilzo/minilzo.o
}

check() {
  cd lzo-${pkgver}

  make test # Larger test
  make check
}

package() {
  cd lzo-${pkgver}

  # Install the package to the system
  make DESTDIR=${pkgdir} install

}
