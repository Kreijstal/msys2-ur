# Maintainer: kreijstal <kreijstal@hotmail.com>

pkgname=libxau
pkgver=1.0.11
pkgrel=1
pkgdesc="X.Org Xauthority library"
arch=('i686' 'x86_64')
url="https://www.x.org/"
license=('MIT')
depends=()
makedepends=('meson' 'ninja' 'gcc' 'ccache' 'xorgproto')
XORG_SRC_COMPRESSION=${XORG_SRC_COMPRESSION:-xz}
source=(https://www.x.org/archive/individual/lib/libXau-${pkgver}.tar.${XORG_SRC_COMPRESSION})
sha256sums=('SKIP')  # Replace SKIP with the actual checksum

prepare() {
  cd ${srcdir}/libXau-${pkgver}

  # Apply any necessary patches here
  autoreconf -vif
}
build() {
  cd ${srcdir}/libXau-${pkgver}

  ./configure --prefix=/usr \
    --libdir=/usr/lib \
    --sysconfdir=/etc \
    --localstatedir=/var \
    --datadir=/usr/share \
    --mandir=/usr/share/man \
    --infodir=/usr/share/info \
    --build=${CHOST} \
    --host=${CHOST}

  make
}


check() {
  cd ${srcdir}/libXau-${pkgver}

  # Add any check commands here
}

package() {
  cd ${srcdir}/libXau-${pkgver}
make DESTDIR=${pkgdir} install
}
