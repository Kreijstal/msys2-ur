pkgname=mesa-opengl-headers
pkgver=26.1.0
pkgrel=1
pkgdesc="Desktop OpenGL headers from Mesa"
arch=('any')
url="https://www.mesa3d.org/"
license=('spdx:MIT')
depends=('xorgproto')
source=("https://mesa.freedesktop.org/archive/mesa-${pkgver}.tar.xz")
sha256sums=('a5095e6dc2986c78f0cef4c5555dc803e93b6bfe5670e991f9e8bd49395bae19')
noextract=("mesa-${pkgver}.tar.xz")

prepare() {
  rm -rf "mesa-${pkgver}"
  bsdtar -xf "${srcdir}/mesa-${pkgver}.tar.xz" \
    "mesa-${pkgver}/include" \
    "mesa-${pkgver}/docs/license.rst"
}

package() {
  cd "mesa-${pkgver}"

  install -d "${pkgdir}/usr/include/GL" "${pkgdir}/usr/include/KHR"
  install -m644 include/GL/{gl,glcorearb,glext,glx,glxext,wglext}.h \
    "${pkgdir}/usr/include/GL/"
  install -m644 include/KHR/khrplatform.h "${pkgdir}/usr/include/KHR/"

  install -d "${pkgdir}/usr/lib/pkgconfig"
  cat > "${pkgdir}/usr/lib/pkgconfig/${pkgname}.pc" <<'EOF'
prefix=/usr
includedir=${prefix}/include
glincludedir=${includedir}/GL

Name: mesa-opengl-headers
Description: Desktop OpenGL headers from Mesa
Version: 26.1.0
EOF

  install -d "${pkgdir}/usr/share/licenses/${pkgname}"
  install -m644 docs/license.rst "${pkgdir}/usr/share/licenses/${pkgname}/"
}
