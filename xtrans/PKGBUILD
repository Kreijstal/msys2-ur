# Maintainer: kreijstal <kreijstal@hotmail.com>

pkgname=xtrans
pkgver=1.5.0
pkgrel=1
pkgdesc="X Window System Protocols Transport layer shared code"
arch=('i686' 'x86_64')
url="https://www.x.org/"
license=('MIT')
depends=()
makedepends=('autoconf' 'automake' 'libtool' 'gcc' 'ccache')

XORG_SRC_COMPRESSION=${XORG_SRC_COMPRESSION:-xz}
source=(https://www.x.org/archive/individual/lib/${pkgname}-${pkgver}.tar.${XORG_SRC_COMPRESSION})
sha256sums=('SKIP')  # Replace SKIP with the actual checksum

prepare() {
  cd ${srcdir}/${pkgname}-${pkgver}

  # Apply any necessary patches here
}

build() {
  cd ${srcdir}/${pkgname}-${pkgver}

  ./configure --prefix=/usr \
    --libdir=/usr/lib \
    --sysconfdir=/etc \
    --localstatedir=/var \
    --datadir=/usr/share \
    --mandir=/usr/share/man \
    --infodir=/usr/share/info \
    --build=${CHOST} \
    --host=${CHOST}

  make
}

check() {
  cd ${srcdir}/${pkgname}-${pkgver}

  # Run any check commands here, such as "make check"
  make check
}

package() {
  cd ${srcdir}/${pkgname}-${pkgver}

  # Install the package to the system
  make DESTDIR=${pkgdir} install
}
