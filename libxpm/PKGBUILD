# Maintainer: kreijstal <kreijstal@hotmail.com>

pkgname=libxpm
urlpkgname=libXpm
pkgver=3.5.17
pkgrel=1
pkgdesc="X11 pixmap library"
arch=('i686' 'x86_64')
url="https://www.x.org/"
license=('MIT')
depends=('libxext' 'libxt' 'libxcb')
makedepends=('xorg-util-macros' 'autoconf' 'automake' 'libtool' 'gcc' 'ccache' 'patch')

XORG_SRC_COMPRESSION=${XORG_SRC_COMPRESSION:-xz}
source=(https://www.x.org/archive/individual/lib/${urlpkgname}-${pkgver}.tar.${XORG_SRC_COMPRESSION}
        dynamic_msys.patch)
sha256sums=('SKIP'
            'SKIP')  # Replace SKIP with the actual checksum

prepare() {
  cd ${srcdir}/${urlpkgname}-${pkgver}

  # Apply the dynamic_msys.patch
  patch -p1 < ${srcdir}/dynamic_msys.patch

  # Run autoreconf to generate configure script from configure.ac
  autoreconf -i
}

build() {
  cd ${srcdir}/${urlpkgname}-${pkgver}

  ./configure --prefix=/usr \
    --libdir=/usr/lib \
    --sysconfdir=/etc \
    --localstatedir=/var \
    --datadir=/usr/share \
    --mandir=/usr/share/man \
    --infodir=/usr/share/info \
    --build=${CHOST} \
    --host=${CHOST}

  make
}

check() {
  cd ${srcdir}/${urlpkgname}-${pkgver}

  make check
}

package() {
  cd ${srcdir}/${urlpkgname}-${pkgver}

  # Install the package to the system
  make DESTDIR=${pkgdir} install
}
