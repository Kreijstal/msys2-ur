# Maintainer: kreijstal <kreijstal@hotmail.com>

pkgname=xeyes
pkgver=1.3.1
pkgrel=1
pkgdesc="Follow the mouse X demo"
arch=('x86_64')
url="https://www.x.org/"
license=('spdx:MIT')
depends=('libx11'
         'libxext'
         'libxi'
         'libxmu'
         'libxrender'
         'libxt')
makedepends=('gcc'
             'make'
             'pkgconf'
             'xorg-util-macros'
             'xorgproto')
source=("https://www.x.org/releases/individual/app/${pkgname}-${pkgver}.tar.xz")
sha256sums=('5608d76b7b1aac5ed7f22f1b6b5ad74ef98c8693220f32b4b87dccee4a956eaa')

build() {
  cd "${pkgname}-${pkgver}"

  ./configure \
    --prefix=/usr \
    --build=${CHOST} \
    --host=${CHOST} \
    --with-xrender \
    --without-present

  make
}

check() {
  cd "${pkgname}-${pkgver}"
  make check
}

package() {
  cd "${pkgname}-${pkgver}"
  make DESTDIR="${pkgdir}" install
  install -Dm644 COPYING "${pkgdir}/usr/share/licenses/${pkgname}/COPYING"
}
