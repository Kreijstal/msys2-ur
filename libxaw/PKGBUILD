# Maintainer: kreijstal <kreijstal@hotmail.com>

pkgname=libxaw
urlpkgname=libXaw
pkgver=1.0.16
pkgrel=1
pkgdesc="Athena Widget library"
arch=('i686' 'x86_64')
url="https://www.x.org/"
license=('MIT')
depends=('libx11' 'libxmu' 'libxext' 'libxpm' 'libxt')
makedepends=('xtrans' 'autoconf' 'automake' 'libtool' 'gcc' 'ccache')

XORG_SRC_COMPRESSION=${XORG_SRC_COMPRESSION:-xz}
source=(https://www.x.org/archive/individual/lib/${urlpkgname}-${pkgver}.tar.${XORG_SRC_COMPRESSION})
sha256sums=('SKIP')  # Replace SKIP with the actual checksum

prepare() {
  cd ${srcdir}/${urlpkgname}-${pkgver}

  # Apply any necessary patches here
}

build() {
  cd ${srcdir}/${urlpkgname}-${pkgver}

  ./configure --prefix=/usr \
    --libdir=/usr/lib \
    --sysconfdir=/etc \
    --localstatedir=/var \
    --datadir=/usr/share \
    --mandir=/usr/share/man \
    --infodir=/usr/share/info \
    --build=${CHOST} \
    --host=${CHOST}

  make
}

check() {
  cd ${srcdir}/${urlpkgname}-${pkgver}

  make check
}

package() {
  cd ${srcdir}/${urlpkgname}-${pkgver}

  # Install the package to the system
  make DESTDIR=${pkgdir} install
}
