# Maintainer: kreijstal <kreijstal@hotmail.com>

pkgname=libthai
pkgver=0.1.29
pkgrel=1
pkgdesc="Thai language support library"
arch=('i686' 'x86_64')
url="https://linux.thai.net/"
license=('LGPL-2.1-or-later')
depends=()
makedepends=('gcc' 'make' 'libdatrie' 'libiconv-devel')
source=(http://linux.thai.net/pub/thailinux/software/libthai/${pkgname}-${pkgver}.tar.xz)
sha256sums=('SKIP')  # Replace SKIP with the actual checksum

prepare() {
  cd ${srcdir}/${pkgname}-${pkgver}

  # Apply any necessary patches here
  autoreconf -vif
}

build() {
  cd ${srcdir}/${pkgname}-${pkgver}

  ./configure --prefix=/usr ${CYGCONF_ARGS}
  make ${MAKEOPTS}
}

check() {
  cd ${srcdir}/${pkgname}-${pkgver}

  # Add any check commands here
}

package() {
  cd ${srcdir}/${pkgname}-${pkgver}

  # Install the library and headers to the package directory
  make install DESTDIR=${pkgdir}
}
