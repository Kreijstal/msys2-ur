+def AvailableProcTypes():
+    global availableProcTypes
+
+    if availableProcTypes is not None:
+        return availableProcTypes
+
+    availableProcTypes = set()
+    for filename in headerFilenames:
+        try:
+            with open(filename, encoding='utf-8', errors='ignore') as header:
+                availableProcTypes.update(re.findall(r'\bPFN[A-Z0-9_]+PROC\b',
+                                                     header.read()))
+        except OSError:
+            print('warning: could not read OpenGL header %s' % filename,
+                  file=sys.stderr)
+
+    return availableProcTypes
+
+def HasProcType(name):
+    if not headerFilenames:
+        return True
+
+    return ('PFN' + name.upper() + 'PROC') in AvailableProcTypes()
